generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  extensions = [postgis]
}

model User {
  id Int @id @default(autoincrement())
  username String @db.VarChar
  email String @unique @db.VarChar
  password String @db.VarChar
  safetyReports SafetyReport[]
  reviews Review[]
}

model Park {
  id Int @id @default(autoincrement())
  name String @db.VarChar
  terrain_data String? @db.VarChar
  mobility_data String? @db.VarChar
  maintenance_stats String? @db.VarChar
  location Unsupported("geography(Point, 4326)")

  amenities ParkAmenity[]
  safetyReports SafetyReport[]
  reviews Review[]
}

model ParkAmenity {
  id Int @id @default(autoincrement())
  park_id Int
  name String @db.VarChar
  description String? @db.VarChar
  park Park @relation(fields: [park_id], references: [id])
}

enum ReportStatus {
  OPEN
  RESOLVED
  PENDING
}

model SafetyReport {
  id Int @id @default(autoincrement())
  user_id Int
  park_id Int
  description String @db.VarChar
  image Bytes?
  status ReportStatus @default(OPEN)
  created_at DateTime @default(now())
  location Unsupported("geography(Point, 4236)")
  user User @relation(fields: [user_id], references: [id])
  park Park @relation(fields: [park_id], references: [id])
}

model Review {
  id Int @id @default(autoincrement())
  user_id Int
  park_id Int
  content String @db.VarChar
  rating Int
  created_at DateTime @default(now())
  user User @relation(fields: [user_id], references: [id])
  park Park @relation(fields: [park_id], references: [id])
}